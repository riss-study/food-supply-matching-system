# Frontend
frontend/node_modules/
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/releases/
!frontend/.yarn/plugins/
!frontend/.yarn/patches/
!frontend/.yarn/versions/
!frontend/.yarn/sdks/
!frontend/.yarn/install-state.gz
frontend/apps/*/dist/
frontend/packages/*/dist/
frontend/apps/*/tsconfig.tsbuildinfo
frontend/packages/*/tsconfig.tsbuildinfo
frontend/apps/*/test-results/
frontend/apps/*/playwright-report/
frontend/**/.env.local
frontend/**/.env.*.local

# Backend
backend/.gradle/
backend/.kotlin/
backend/**/build/
backend/.tmp-bootstrap/
backend/**/backend/local-storage/

# Secrets — env 파일과 local profile yml 은 절대 커밋 금지.
# *.example 파일만 commit, 개발자가 복사 후 자기 secret 채워서 사용.
.env
.env.local
backend/.env
backend/**/application-local.yml
!backend/**/application-local.yml.example

# IDE / OS
.DS_Store
.idea/
.vscode/
backend/local-storage/

# Claude memory (local-only)
memories/
